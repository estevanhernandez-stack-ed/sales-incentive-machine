{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sim.local/runbooks/scenario-schema.json",
  "title": "SIM runbook scenario",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "title", "role", "runbook_id", "purpose", "starting_state", "fixtures", "assignments", "required_steps", "success_conditions", "intentional_discoveries"],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "role": { "enum": ["contest_manager", "shift_manager"] },
    "runbook_id": { "enum": ["contest-manager", "shift-manager"] },
    "purpose": { "type": "string", "minLength": 1 },
    "starting_state": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "fixtures": { "type": "object" },
    "assignments": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "required_steps": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^(CM|SM)-[0-9]{2}$" } },
    "success_conditions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "intentional_discoveries": { "type": "array", "items": { "type": "string" } }
  }
}
