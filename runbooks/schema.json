{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sim.local/runbooks/schema.json",
  "title": "SIM executable runbook",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "title", "role", "purpose", "authority", "steps"],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "role": { "enum": ["contest_manager", "shift_manager"] },
    "purpose": { "type": "string", "minLength": 1 },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed", "forbidden"],
      "properties": {
        "allowed": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "forbidden": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "phase", "title", "instruction", "mode", "preconditions", "expected", "confirmation", "allowed_tools", "forbidden_shortcuts", "evidence", "observations", "recovery"],
        "properties": {
          "id": { "type": "string", "pattern": "^(CM|SM)-[0-9]{2}$" },
          "phase": { "enum": ["preflight", "setup", "live", "finalize", "evidence", "debrief"] },
          "title": { "type": "string", "minLength": 1 },
          "instruction": { "type": "string", "minLength": 1 },
          "mode": { "enum": ["read", "ui_write", "api_write", "decision", "debrief"] },
          "preconditions": { "type": "array", "items": { "type": "string" } },
          "expected": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "confirmation": { "enum": ["none", "explicit"] },
          "allowed_tools": { "type": "array", "items": { "type": "string" } },
          "forbidden_shortcuts": { "type": "array", "items": { "type": "string" } },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "required", "ui_path", "wait_for", "capture_name", "receipt_required"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "required": { "type": "boolean" },
                "ui_path": { "type": "string", "pattern": "^/" },
                "wait_for": { "type": "string", "minLength": 1 },
                "capture_name": { "type": "string", "pattern": "^[a-zA-Z0-9._-]+\\.png$" },
                "receipt_required": { "type": "boolean" }
              }
            }
          },
          "observations": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "recovery": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    }
  }
}
