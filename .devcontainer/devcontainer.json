{
  "name": "SIM: Sales Incentive Machine",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "postCreateCommand": "npm install && npm run seed",
  "postAttachCommand": {
    "server": "npm run dev"
  },
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "SIM",
      "onAutoForward": "openPreview"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss"
      ]
    }
  }
}
